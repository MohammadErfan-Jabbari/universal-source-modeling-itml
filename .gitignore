# Live-day released data should not be committed by default
# Keep public practice and generator data tracked, but keep secret/live drops local.
data/live_release/

# Large local model/artifact drops
models/
artifacts/

# Activity B generated data/results/model caches
activity_b_llmzip/data/*
!activity_b_llmzip/data/.gitkeep
activity_b_llmzip/results/*
!activity_b_llmzip/results/.gitkeep
activity_b_llmzip/model_cache/
activity_b_llmzip/**/*.npy
activity_b_llmzip/**/*.npz

# Copyright: course material kept LOCAL only (professor's slides + OCR lecture notes).
# These are intentionally untracked and must never be committed to the public repo.
lectures/
docs/*.pdf

# Reorg working scratchpad (orchestration notes; not part of the published repo).
.reorg/
